# Opzionale: per usare Google Maps JavaScript API al posto dei tile Esri
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Opzionale: terreno 3D Cesium (monti, laghi specchiati) — https://ion.cesium.com/tokens
# NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Assistente Mastro Fungaiolo (Google Gen AI SDK) — Server Action chatWithMastro
# Crea la chiave su https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_CHAT_MODEL=gemini-2.5-flash
