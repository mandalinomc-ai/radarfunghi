# Opzionale: per usare Google Maps JavaScript API al posto dei tile Esri
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Opzionale: terreno 3D Cesium (monti, laghi specchiati) — https://ion.cesium.com/tokens
# NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Assistente Mastro Fungaiolo (Google Gen AI SDK) — Server Action chatWithMastro
# Crea la chiave su https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# URL pubblico app (Telegram webhook + link bot)
# NEXT_PUBLIC_APP_URL=https://radar-funghi.vercel.app

# Telegram Bot (@BotFather) — webhook + allerte Pro
# NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/RADARFUNGHIBOT
# NEXT_PUBLIC_TELEGRAM_GROUP_URL=https://t.me/RADARFUNGHIBOT?startgroup=community
# NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/RADARFUNGHIBOT?start=canale
# TELEGRAM_GROUP_CHAT_ID=-100xxxxxxxxxx
# TELEGRAM_WEBHOOK_SECRET=random_secret_for_webhook_header

# Cron protezione (/api/cron/refresh, /api/telegram/notify, /api/telegram/setup)
# CRON_SECRET=your_random_secret
